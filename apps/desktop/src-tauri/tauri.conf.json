{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "HAETAE",
  "version": "0.1.0",
  "identifier": "com.haetae.console",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "pnpm --parallel --filter haetae-web --filter haetae-server dev"
  },
  "app": {
    "windows": [
      {
        "title": "HAETAE",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
