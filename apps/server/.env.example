# Server-only environment — never exposed to the web bundle.

# `production` switches single-origin mode on (server hosts apps/web/dist).
# Anything else (or unset) keeps Vite + Fastify on separate origins for dev.
NODE_ENV=development

# Anthropic Admin API key (Phase 5 — usage report)
ANTHROPIC_ADMIN_KEY=

# Server bind port (default 3001). Web vite proxy reads HAETAE_SERVER_PORT too.
HAETAE_SERVER_PORT=3001

# Local SQLite cache path (default uses OS-standard data dir)
HAETAE_DB_PATH=

# Override Claude Code home directory (default ~/.claude)
HAETAE_CLAUDE_HOME=

# Project root paths to surface in the sidebar (colon-separated). Each entry
# should be the directory that contains a .claude/ subdirectory. This is a
# read-only seed — for ad-hoc add/remove use the Settings UI instead, which
# writes into the project_roots DB table and merges with this list.
# Example:
#   HAETAE_PROJECT_ROOTS=/Users/me/Documents/GitHub/Demo:/Users/me/Documents/GitHub/Other
HAETAE_PROJECT_ROOTS=

# Debug logging
HAETAE_DEBUG=false

# Opt-in: Claude /config 의 진짜 5h / 7d 한도 % 를 HAETAE 에 노출.
#
# `true` 로 설정하면 macOS Keychain 의 OAuth 토큰을 읽어 Anthropic 의
# 비공식 endpoint `https://api.anthropic.com/api/oauth/usage` 를 직접
# 호출. claude CLI 가 내부적으로 같은 endpoint 를 쓰지만 공식 문서는
# 없음 — Anthropic 이 schema 를 변경 / 봉쇄 가능. 깨지면 자동으로
# Settings 임계치 fallback 으로 돌아감 (#141 / #153).
#
# 근거: docs/research/claude-code-data-sources.md
# 미설정 (또는 false) 시: Settings 의 사용자 임계치만 사용
# HAETAE_USE_OAUTH_LIMITS=true

# --- Wiki auto-update (closes the self-improving loop) ---
# Off by default because each update spends Claude quota (runs `claude --print`).
# When true, a background scheduler incrementally updates EXISTING project wikis
# (never auto-creates a first wiki) once a project has settled. Heavily rate-
# limited: one project per tick, per-project cooldown, single-flight.
HAETAE_WIKI_AUTO=false
# Scheduler tick interval (ms, default 300000 = 5 min)
HAETAE_WIKI_AUTO_INTERVAL_MS=300000
# A project must have had no new messages for this long to be eligible
# (ms, default 600000 = 10 min) — prevents summarizing mid-session.
HAETAE_WIKI_AUTO_DEBOUNCE_MS=600000
# Minimum gap between auto-generations of the same project (ms, default 1800000 = 30 min)
HAETAE_WIKI_AUTO_COOLDOWN_MS=1800000
# Max chars of wiki injected into a project's .claude/CLAUDE.md (default 8000).
# The full wiki stays in HAETAE; CLAUDE.md loads into every session so this caps
# the per-session context cost. Over the cap, highest-value sections are kept.
HAETAE_WIKI_CLAUDEMD_MAX_CHARS=8000

# Max concurrent `claude --print` subprocesses across all second-brain features
# (wiki/ontology/ask/eval/voice + auto scheduler). Calls beyond this queue.
HAETAE_LLM_MAX_CONCURRENT=2
